# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# LLM backend: only "ollama" is currently supported in this project
LLM_PROVIDER=ollama

# Ollama model name (must be pulled first: ollama pull llama3)
OLLAMA_MODEL=llama3

# Sentence-Transformers embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2
